# Alpaca Markets credentials
APCA_API_KEY_ID=your_alpaca_key_id
APCA_API_SECRET_KEY=your_alpaca_secret_key
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# ThetaData credentials
# THETADATA_API_KEY is used to launch ThetaTerminal.jar, NOT for REST API calls.
# The terminal authenticates upstream with your subscriber credentials at startup.
THETADATA_API_KEY=your_thetadata_api_key
# Optional: override the local terminal address (default: http://127.0.0.1:25510/v2)
# THETADATA_BASE_URL=http://127.0.0.1:25510/v2
